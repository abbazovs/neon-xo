################################################
# NEON XO — Environment Variables
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# On Railway, set these in the service "Variables" tab.
# Railway automatically injects DATABASE_URL and REDIS_URL
# when you add Postgres and Redis plugins to your project.
################################################

# --- Runtime ---
# One of: development | staging | production | test
NODE_ENV=development

# Port the backend listens on. Railway sets this automatically.
PORT=3000

# --- Database ---
# Full Postgres connection string.
# Railway: click Postgres plugin → "Connect" → use ${{ Postgres.DATABASE_URL }}
# Local: postgres://user:pass@localhost:5432/neonxo
DATABASE_URL=postgres://postgres:postgres@localhost:5432/neonxo

# --- Redis ---
# Full Redis connection string.
# Railway: click Redis plugin → "Connect" → use ${{ Redis.REDIS_URL }}
# Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# --- Auth ---
# JWT signing secret. MUST be at least 32 characters.
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# How long JWTs last. Use values like "30d", "12h", "7d".
JWT_EXPIRES_IN=30d

# --- CORS ---
# Comma-separated list of allowed origins, or "*" for all.
# In production, set to your actual domain: https://yourapp.up.railway.app
CORS_ORIGIN=*

# --- App config ---
# Public URL of your app (used for generating share links, metadata).
APP_URL=http://localhost:3000

# Match invite link expiry in minutes.
MATCH_INVITE_EXPIRY_MINUTES=60

# Grace period (ms) before declaring auto-win on disconnect. 0 = immediate.
DISCONNECT_GRACE_MS=0

# Delete abandoned/voided matches older than N days (nightly cleanup job).
ABANDONED_MATCH_CLEANUP_DAYS=7

# --- Rate limiting ---
# Rolling window (ms) for the per-user API rate limiter.
RATE_LIMIT_WINDOW_MS=1000

# Max requests per window.
RATE_LIMIT_MAX=10
